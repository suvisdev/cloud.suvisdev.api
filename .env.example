# 이 파일을 복사해 `.env`로 저장한 뒤 값을 채우세요. (`.env`는 Git에 올리지 마세요.)

# Neon 등 PostgreSQL 비동기 연결 문자열
# Neon Dashboard → Connection string 복사 (비밀번호 변경 시 전체 문자열 교체)
# 예: postgresql+psycopg://USER:PASSWORD@HOST/neondb?sslmode=require
# channel_binding=require 는 넣지 마세요 (psycopg 비동기 호환 문제)
DATABASE_URL=

# Google Gemini API 키 — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# (선택) 기본 모델 ID. 구형 gemini-1.5-* 는 자동으로 2.5로 대체됩니다.
# 프론트: flash → gemini-2.5-flash-lite, flash15 → gemini-2.5-flash, pro → gemini-2.5-pro
# GEMINI_MODEL=gemini-2.5-flash

# OpenWeatherMap — https://openweathermap.org/api (Current Weather)
OPENWEATHERMAP_API_KEY=

# (선택) 도시명. 기본: Seoul
# OPENWEATHER_CITY=Seoul

# TMDB(The Movie Database) — https://www.themoviedb.org/settings/api
# 인기 영화·검색 데이터를 Mova DB에 적재 (서버 기동 시 영화 12편 미만이면 자동 시드)
TMDB_API_KEY=

# KOFIC(KOBIS) 오픈 API — http://www.kobis.or.kr/kobisopenapi/homepg/main/main.do
# 일간/주간 박스오피스를 Mova DB/HOT 랭킹으로 반영할 때 사용
KOFIC_API_KEY=
