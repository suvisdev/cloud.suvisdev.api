[importlinter]
root_packages =
    star_craft
    titanic
    mova
    viewer
    silicon_valley
    friday13th
    imitation_game
    inception
    social_network
    core

# ──────────────────────────────────────────────
# 규칙 1: Hub(star_craft)는 Spoke를 import하지 않는다
# ──────────────────────────────────────────────
[importlinter:contract:hub-independence]
name = Hub (star_craft) must not depend on any spoke
type = forbidden
source_modules =
    star_craft
forbidden_modules =
    titanic
    mova
    viewer
    silicon_valley
    friday13th
    imitation_game
    inception
    social_network

# ──────────────────────────────────────────────
# 규칙 2: Spoke 간 직접 의존 금지 (Cross-Spoke Dependency)
# ──────────────────────────────────────────────
[importlinter:contract:spoke-independence]
name = Spokes must not import each other directly (star topology)
type = independence
modules =
    titanic
    mova
    viewer
    silicon_valley
    friday13th
    imitation_game
    inception
    social_network
